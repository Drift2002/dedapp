rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow read/write only if the user is authenticated and is accessing their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow read/write to the assessments subcollection for the same user
      match /assessments/{assessmentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Allow read/write to the screenTime subcollection for the same user
      match /screenTime/{dayId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
